#!/usr/bin/env bash
set -euo pipefail

readonly REPO="${NIX_TEMPLATES_FLAKE:-github:RKildegaard/nix-templates}"
readonly TEMPLATE_ROOT="${TEMPLATE_ROOT:-templates}"
readonly COLOR_OK=10
readonly COLOR_INFO=4
readonly COLOR_TITLE=2
readonly COLOR_MUTED=7

usage() {
  cat <<'EOF'
Usage: template-menu

Interactive helper for:
  nix flake init -t github:RKildegaard/nix-templates#<template>

Environment:
  NIX_TEMPLATES_FLAKE  Override flake ref (default: github:RKildegaard/nix-templates)
  TEMPLATE_ROOT        Override output key with templates (default: templates)
EOF
}

die() {
  echo "error: $*" >&2
  exit 1
}

require_cmds() {
  local cmd
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || die "$cmd is required for this script"
  done
}

fetch_templates_json() {
  # Prints JSON to stdout
  gum spin --title "Refreshing template list" -- \
    nix eval --refresh --json "${REPO}#${TEMPLATE_ROOT}"
}

# Converts flake template JSON to TSV lines: "name<TAB>description"
json_to_tsv() {
  jq -r '
    to_entries
    | sort_by(.key)
    | .[]
    | [.key, (.value.description // "")]
    | @tsv
  '
}

# Category is prefix up to first '-' (or whole name if none)
template_category() {
  awk -F- '{print $1}'
}

choose_category() {
  local -a categories menu lines
  local cat count selected_label

  lines=("$@")
  mapfile -t categories < <(
    printf '%s\n' "${lines[@]}" |
      cut -f1 |
      template_category |
      sort -u
  )

  menu=("All templates (${#lines[@]})")
  for cat in "${categories[@]}"; do
    count=$(
      printf '%s\n' "${lines[@]}" |
        awk -F'\t' -v cat="$cat" '$1 == cat || index($1, cat "-") == 1 { n++ } END { print n + 0 }'
    )
    menu+=("${cat} (${count})")
  done

  selected_label="$(printf '%s\n' "${menu[@]}" | gum choose \
    --header "Choose template category" \
    --height 10
  )" || return 1

  if [[ "$selected_label" == All\ templates\ \(*\) ]]; then
    printf '%s\n' "All templates"
  else
    printf '%s\n' "${selected_label% (*}"
  fi
}

filter_by_category() {
  local category="$1"
  shift

  if [[ "$category" == "All templates" ]]; then
    printf '%s\n' "$@"
    return 0
  fi

  # Match either exact category name OR prefix "category-..."
  printf '%s\n' "$@" |
    awk -F'\t' -v cat="$category" '$1 == cat || index($1, cat "-") == 1'
}

choose_template_line() {
  local -a lines=("$@")

  if [[ ${#lines[@]} -eq 1 ]]; then
    printf '%s\n' "${lines[0]}"
    return 0
  fi

  printf '%s\n' "${lines[@]}" | gum filter \
    --header "Pick a template (type to search)" \
    --height 12 \
    --placeholder "Search templates..." \
    --limit 1
}

normalize_dir() {
  local dir="${1:-.}"

  # Expand "~" (only when it is the first character)
  dir="${dir/#~/$HOME}"
  # Trim trailing slash
  dir="${dir%/}"
  # Guard against empty
  [[ -n "$dir" ]] || dir="."

  printf '%s\n' "$dir"
}

print_selection() {
  local name="$1"
  local desc="$2"

  printf '\n'
  gum style --foreground "$COLOR_TITLE" --bold "Selected template: $name"
  [[ -n "$desc" ]] && gum style --foreground "$COLOR_MUTED" "$desc"
}

main() {
  case "${1:-}" in
    -h|--help) usage; exit 0 ;;
  esac

  require_cmds gum jq nix

  local json
  json="$(fetch_templates_json)" || die "unable to read ${TEMPLATE_ROOT} from ${REPO}"

  local -a template_lines
  mapfile -t template_lines < <(printf '%s\n' "$json" | json_to_tsv)

  [[ ${#template_lines[@]} -gt 0 ]] || die "No templates found in ${REPO}#${TEMPLATE_ROOT}"

  local selected_category
  selected_category="$(choose_category "${template_lines[@]}")" || exit 1

  local -a pool
  mapfile -t pool < <(filter_by_category "$selected_category" "${template_lines[@]}")
  [[ ${#pool[@]} -gt 0 ]] || die "No templates in category: $selected_category"

  local selected_line
  selected_line="$(choose_template_line "${pool[@]}")" || exit 1

  local template_name template_description
  template_name="${selected_line%%$'\t'*}"
  template_description="${selected_line#*$'\t'}"
  [[ "$template_description" != "$selected_line" ]] || template_description=""

  print_selection "$template_name" "$template_description"

  local target_dir
  target_dir="$(gum input \
    --value "." \
    --placeholder "Directory to create the project in (relative or absolute)" \
    --header "Press ENTER to initialize in current directory" \
    --width 60
  )" || exit 1

  target_dir="$(normalize_dir "$target_dir")"
  [[ "$target_dir" == "." ]] || mkdir -p "$target_dir"

  gum style --foreground "$COLOR_INFO" "Initializing $template_name in $target_dir"

  (
    cd "$target_dir"
    nix flake init -t "${REPO}#${template_name}"
  ) || die "nix flake init failed"

  gum style --foreground "$COLOR_OK" --bold "Template created successfully"

  if command -v direnv >/dev/null 2>&1; then
    gum style --foreground 6 "direnv detected"
    if [[ "$target_dir" == "." ]]; then
      echo "direnv allow"
    else
      echo "cd \"$target_dir\" && direnv allow"
    fi
  fi
}

main "$@"
